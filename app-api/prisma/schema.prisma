generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Admin {
  id                  String         @id @default(auto()) @map("_id") @db.ObjectId
  name                String
  email               String         @unique
  passwordHash        String
  role                String         @default("editor") // admin | editor
  status              String         @default("active") // active | disabled
  failedLoginAttempts Int            @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  sessions            AdminSession[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model User {
  id                  String         @id @default(auto()) @map("_id") @db.ObjectId
  env                 String         @default("dev") // dev | production
  email               String
  clerkId             String?
  name                String
  passwordHash        String
  stripeCustomerId    String?        // Stripe customer ID for billing portal
  status              String         @default("active") // active | disabled
  parentId            String?        @db.ObjectId
  ancestors           String[]       @db.ObjectId // materialized path of parent IDs (e.g. [parentId])
  failedLoginAttempts Int            @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  parent              User?          @relation("UserHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children            User[]         @relation("UserHierarchy")
  sessions            UserSession[]
  purchases           Purchase[]
  memberships         Membership[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@unique([env, email])
  @@index([env, clerkId])
}

model UserSession {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  env       String   @default("dev") // dev | production
  userId    String   @db.ObjectId
  tokenHash String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminSession {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  adminId   String   @db.ObjectId
  tokenHash String   @unique
  expiresAt DateTime
  admin     Admin    @relation(fields: [adminId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  env        String   @default("dev") // dev | production
  actor      String // "admin" | "user" | "system"
  actorId    String?  @db.ObjectId
  actorEmail String?
  action     String // e.g. "admin.login", "user.register", "admin.create"
  resource   String? // e.g. "admin", "user", "profile"
  resourceId String?  @db.ObjectId
  metadata   Json?
  ip         String?
  userAgent  String?
  method     String? // HTTP method
  path       String? // Request path
  createdAt  DateTime @default(now())
}

model Product {
  id                  String         @id @default(auto()) @map("_id") @db.ObjectId
  env                 String         @default("dev") // dev | production
  name                String
  slug                String
  description         String?
  type                String         @default("physical") // physical | digital | membership
  price               Float          @default(0)
  currency            String         @default("USD")
  paymentModel        String         @default("one-time") // one-time | recurring
  interval            String?        // month | year (for recurring products)
  maxSubUsers         Int            @default(0) // 0 = none, -1 = unlimited
  fileUrls            String[]       // For digital download products
  accessKeys          String[]       // Feature keys unlocked by purchase
  stripeTestProductId String?        // Stripe product ID (test mode)
  stripeTestPriceId   String?        // Stripe price ID (test mode)
  stripeLiveProductId String?        // Stripe product ID (live mode)
  stripeLivePriceId   String?        // Stripe price ID (live mode)
  isActive            Boolean        @default(true)
  sortOrder           Int            @default(0)
  metadata            Json?
  purchases           Purchase[]
  prices              ProductPrice[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@unique([env, slug])
}

model ProductPrice {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  env             String    @default("dev") // dev | production
  productId       String    @db.ObjectId
  label           String    // e.g. "Monthly 2024", "Launch Offer"
  stripePriceId   String    // Stripe price ID
  mode            String    @default("test") // test | live
  amount          Float
  currency        String    @default("USD")
  interval        String?   // month | year (null for one-time)
  startDate       DateTime  @default(now())
  endDate         DateTime? // null = no end date (active indefinitely)
  isDefault       Boolean   @default(false)
  metadata        Json?
  product         Product   @relation(fields: [productId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Purchase {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  env             String         @default("dev") // dev | production
  userId          String         @db.ObjectId
  productId       String         @db.ObjectId
  status          String         @default("completed") // pending | completed | refunded | failed | active | cancelled | expired
  amount          Float
  currency        String         @default("USD")
  externalId      String?        // Payment provider reference
  startDate       DateTime       @default(now())
  endDate         DateTime?
  cancelledAt     DateTime?
  metadata        Json?
  user            User           @relation(fields: [userId], references: [id])
  product         Product        @relation(fields: [productId], references: [id])
  files           PurchaseFile[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model PurchaseFile {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  env        String   @default("dev") // dev | production
  purchaseId String   @db.ObjectId
  fileName   String   // Display name
  mimeType   String   @default("application/octet-stream")
  sizeBytes  Int      @default(0)
  data       String   // base64-encoded file content (temporary approach)
  metadata   Json?
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Membership {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  env         String    @default("dev") // dev | production
  userId      String    @db.ObjectId
  type        String // "purchase"
  sourceId    String    @db.ObjectId // purchaseId
  featureKeys String[] // Features granted by this membership
  status      String    @default("active") // active | expired | revoked
  expiresAt   DateTime?
  user        User      @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Feature {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  env         String   @default("dev") // dev | production
  key         String
  description String
  category    String
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([env, key])
}

model SiteSetting {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  env       String   @default("dev") // dev | production
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([env, key])
}

model CheckoutSession {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  env        String   @default("dev") // dev | production
  sessionId  String   @unique // Payment provider session ID
  userId     String?  @db.ObjectId // null for guest checkout
  guestEmail String? // Guest checkout email
  guestName  String? // Guest checkout name
  items      Json // [{productId, quantity, priceId}]
  status     String   @default("pending") // pending | completed | expired
  provider   String   @default("stripe") // stripe | woocommerce (future)
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

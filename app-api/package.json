{
  "name": "app-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 7001",
    "prebuild": "vitest run",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "npx prisma generate",
    "prisma:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "setup": "pnpm install && pnpm run prisma:push && pnpm run db:seed"
  },
  "dependencies": {
    "@clerk/backend": "^3.4.4",
    "@prisma/client": "^5.22.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
